# Mode: "local" (Ollama) or "remote" (Google Gemini)
CHAT_MODE=remote

# Required only if CHAT_MODE=remote
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=<your_google_ai_studio_api_key>

# Models to use in each mode
REMOTE_MODEL=gemini-2.5-flash
LOCAL_MODEL=llama3.2

# Ollama server URL (local mode only — default port is 11434)
OLLAMA_BASE_URL=http://localhost:11434

# Chatbot personality (system prompt — defines how the model behaves)
SYSTEM_PROMPT=You are a helpful and concise technical assistant.

# How many conversation turns to remember (1 turn = 1 question + 1 answer = 2 messages)
MAX_HISTORY_TURNS=10

# Maximum allowed length for user messages (in characters)
MAX_INPUT_CHARS=500
